# ── Required — app will NOT start without these ───────────────────────────────
DASHBOARD_PASSWORD=choose-a-strong-password
SECRET_KEY=run-openssl-rand-hex-32-and-paste-here

# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add the Postgres plugin.
# For local dev, set this manually.
# Supported schemes: postgres://, postgresql://, postgresql+asyncpg:// (all normalised)
DATABASE_URL=postgresql+asyncpg://tracker:tracker@localhost:5432/tracker

# ── Google Sheets sync (optional — leave blank to disable) ───────────────────
# Railway can't mount files, so paste the full service-account JSON here.
# Copy the contents of your service_account.json and collapse to a single line.
GOOGLE_CREDENTIALS_JSON=

# Sheet ID from the URL: https://docs.google.com/spreadsheets/d/<THIS>/edit
GOOGLE_SHEET_ID=

# How often (seconds) the in-memory event queue is flushed to Sheets
SHEETS_BATCH_INTERVAL=10

# ── Tracking behaviour ────────────────────────────────────────────────────────
# Hours of silence after send before a link is counted as "ignored"
IGNORED_THRESHOLD_HOURS=48
