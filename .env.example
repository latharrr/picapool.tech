# ── Required — app will NOT start without these ───────────────────────────────
DASHBOARD_PASSWORD=choose-a-strong-password
SECRET_KEY=run-openssl-rand-hex-32-and-paste-here

# ── Google Sheets (the only data store) ──────────────────────────────────────
# Sheet ID from the URL: https://docs.google.com/spreadsheets/d/<THIS>/edit
GOOGLE_SHEET_ID=your-sheet-id-here

# Paste the full service_account.json contents on one line (Railway)
#   cat service_account.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
GOOGLE_CREDENTIALS_JSON=

# File path fallback (local dev only)
# GOOGLE_SHEETS_CREDENTIALS_PATH=service_account.json

# ── Groq AI (optional — enables /api/analyze) ─────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# ── Tuning ────────────────────────────────────────────────────────────────────
SHEETS_BATCH_INTERVAL=10        # seconds between event flushes to Sheets
CACHE_TTL_SECONDS=30            # how often the in-memory Sheets cache refreshes
IGNORED_THRESHOLD_HOURS=48      # hours of silence before a link counts as ignored
